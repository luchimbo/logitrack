## Core
TURSO_DATABASE_URL=libsql://<tu-db>.turso.io
TURSO_AUTH_TOKEN=<tu-token>
TURSO_DATABASE_URL_PROD=libsql://<tu-db-prod>.turso.io
TURSO_AUTH_TOKEN_PROD=<tu-token-prod>
JWT_SECRET=<hex-64-o-secreto-largo>

## App URL (frontend + callbacks)
NEXT_PUBLIC_APP_URL=https://tu-dominio.com

## Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx

## Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=<browser-key>
GOOGLE_MAPS_API_KEY=<server-key-opcional>

## Zipnova API (si usas integracion directa)
ZIPNOVA_API_TOKEN=<zipnova-api-token>
ZIPNOVA_API_SECRET=<zipnova-api-secret>

## Zipnova OAuth (si usas OAuth)
ZIPNOVA_OAUTH_CLIENT_ID=<zipnova-oauth-client-id>
ZIPNOVA_OAUTH_CLIENT_SECRET=<zipnova-oauth-client-secret>
ZIPNOVA_OAUTH_CALLBACK_URL=https://tu-dominio.com/api/integrations/zipnova/callback
ZIPNOVA_OAUTH_BASE_URL=https://api.zipnova.com.ar

## Cifrado interno Zipnova (32 bytes en hex = 64 chars)
ZIPNOVA_ENCRYPTION_KEY=<hex-64>

## Tiendanube
NEXT_PUBLIC_TIENDANUBE_APP_ID=<tiendanube-app-id>
TIENDANUBE_APP_ID=<tiendanube-app-id>
TIENDANUBE_CLIENT_SECRET=<tiendanube-client-secret>
TIENDANUBE_CALLBACK_URL=https://tu-dominio.com/api/integrations/tiendanube/callback

## Shopify
SHOPIFY_API_KEY=<shopify-api-key>
SHOPIFY_API_SECRET=<shopify-api-secret>
SHOPIFY_SCOPES=read_orders,read_merchant_managed_fulfillment_orders,write_merchant_managed_fulfillment_orders
SHOPIFY_CALLBACK_URL=https://tu-dominio.com/api/integrations/shopify/callback
SHOPIFY_API_VERSION=2026-04

## Correo Argentino / MiCorreo (MVP local)
CORREO_ARGENTINO_BASE_URL=https://apitest.correoargentino.com.ar/paqar/v1
CORREO_ARGENTINO_API_KEY=<api-key-opcional>
CORREO_ARGENTINO_AGREEMENT=<convenio-opcional>
CORREO_ARGENTINO_SELLER_ID=<seller-id-opcional>

## Print agent V2 (app server)
PRINT_AGENT_TOKEN=<token-secreto-opcional-recomendado>

## Print agent V2 (cliente local / opcional)
PRINT_V2_PRINTER_PATH=\\127.0.0.1\TU_SHARE
PRINT_V2_SYNC_URL=https://tu-dominio.com/api/v2/print-jobs/intake
PRINT_V2_SYNC_TOKEN=<sync-token>
PRINT_V2_WORKSPACE_KEY=<workspace-key>
PRINT_V2_DRY_RUN=0

## Variables legacy detectadas en .env.local pero no usadas en codigo actual
STADIA_MAPS_API_KEY=<opcional>
NEXT_PUBLIC_STADIA_MAPS_API_KEY=<opcional>
